# Local-mock build needs NO external services.
# SQLite file path (optional — defaults to ./bettercal.db)
# DATABASE_URL=file:./bettercal.db

# The variables below are only needed when you re-enable real providers
# (Google OAuth, CalDAV, Resend email) in a later phase:
# ENCRYPTION_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# RESEND_API_KEY=
# EMAIL_FROM=
